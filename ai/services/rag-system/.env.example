# LLM Configuration (DeepSeek)
DEEPSEEK_API_KEY=??
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4000

# Embeddings Configuration
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=deepvk/USER-bge-m3
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=100


# Vector Database (Qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=??
QDRANT_COLLECTION_NAME=medical_documents
QDRANT_TIMEOUT=30

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rag_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20

# Redis (для кеширования)
REDIS_URL=redis://localhost:6379/0
REDIS_TTL=3600

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_INPUT_TOPIC=json-outgoing
KAFKA_STATUS_TOPIC=document.status
KAFKA_CONSUMER_GROUP=python-group

# MinIO / S3
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=admin12345
MINIO_SECURE=false
MINIO_INPUT_BUCKET=processed-json-doc

# Обработка
TEMP_DIR=/tmp/jsn-rag

# API Configuration
API_HOST=0.0.0.0
API_PORT=8001
API_WORKERS=4
API_RELOAD=true

# Retrieval Settings
RETRIEVAL_TOP_K=10
RETRIEVAL_SIMILARITY_THRESHOLD=0.7
HYBRID_SEARCH_WEIGHT_SEMANTIC=0.7
HYBRID_SEARCH_WEIGHT_LEXICAL=0.3

# Chunking Strategy
CHUNK_SIZE=512
CHUNK_OVERLAP=128
MIN_CHUNK_SIZE=100

# Dialogue Settings
MAX_CLARIFYING_QUESTIONS=3
ANAMNESIS_TIMEOUT_SECONDS=300

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
STRUCTLOG_DEV_MODE=true

# Service
SERVICE_NAME=rag-system
SERVICE_VERSION=0.1.0
ENVIRONMENT=dev

# Observability
ENABLE_METRICS=true
METRICS_PORT=9090
ENABLE_TRACING=false
JAEGER_ENDPOINT=
