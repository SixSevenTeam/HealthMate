@startuml architecture
!theme plain
skinparam componentStyle uml2
skinparam defaultFontSize 12

title HealthMate RAG System — Архитектура компонентов

package "Java Backend" as java {
    [Spring API] as spring
}

package "RAG System (Python)" as rag {

    package "API Layer" as api_layer {
        [FastAPI\n/ai/chat] as chat_ep
        [FastAPI\n/api/v1/query] as query_ep
    }

    package "Dialogue" as dialogue_pkg {
        [DialogueService] as dialogue
        [SessionManager] as sessions
        [Prompts] as prompts
    }

    package "Retrieval" as retrieval_pkg {
        [HybridRetriever] as retriever
        [ChunkingService] as chunker
    }

    package "Application" as app_pkg {
        [DocumentProcessor] as doc_proc
    }

    package "Core" as core_pkg {
        [EmbeddingService] as embeddings
        [LLMClient] as llm
        [Settings] as config
    }

    package "Medical" as medical_pkg {
        [SafetyChecker] as safety
        [Disclaimer] as disclaimer
    }

    package "Infrastructure" as infra_pkg {
        [Kafka Consumer] as kafka_in
        [Kafka Producer] as kafka_out
        [MinIO Client] as minio_client
    }
}

cloud "External Services" as external {
    database "Qdrant\n(Vector DB)" as qdrant
    database "Redis\n(Sessions)" as redis
    database "PostgreSQL" as pg
    queue "Kafka" as kafka
    storage "MinIO\n(S3)" as minio
    cloud "DeepSeek\nLLM API" as deepseek
}

spring -down-> chat_ep : "POST /ai/chat"
spring -down-> query_ep : "POST /api/v1/query"

chat_ep -down-> dialogue
query_ep -down-> dialogue

dialogue -down-> sessions
dialogue -down-> retriever
dialogue -down-> llm
dialogue -down-> safety
dialogue -right-> prompts
dialogue -right-> disclaimer

retriever -down-> embeddings
retriever -down-> qdrant

doc_proc -down-> chunker
doc_proc -down-> embeddings
doc_proc -down-> qdrant
doc_proc -down-> kafka_out
doc_proc -left-> minio_client

kafka_in -right-> doc_proc

sessions -down-> redis
llm -down-> deepseek
minio_client -down-> minio
kafka_in -down-> kafka
kafka_out -down-> kafka
embeddings -down-> config

@enduml
