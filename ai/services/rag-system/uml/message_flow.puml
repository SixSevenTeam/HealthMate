@startuml message_flow
!theme plain
skinparam defaultFontSize 12
skinparam sequenceMessageAlign center

title HealthMate RAG System — Поток сообщений

actor "Пользователь" as user
participant "Java Backend\n(Spring)" as java
participant "FastAPI\n/ai/chat" as api
participant "DialogueService" as dialogue
participant "SessionManager\n(Redis)" as session
participant "LLMClient\n(DeepSeek)" as llm
participant "HybridRetriever" as retriever
participant "EmbeddingService" as embed
participant "VectorStore\n(Qdrant)" as qdrant
participant "SafetyChecker" as safety

== Этап 1: Сбор анамнеза (ANAMNESIS) ==

user -> java : Сообщение о симптомах
java -> api : POST /ai/chat\n{session_id, user_context, message}
api -> dialogue : process_query(QueryRequest)
dialogue -> session : get_or_create(session_id)
session --> dialogue : Session(stage=ANAMNESIS)
dialogue -> llm : chat(ANAMNESIS_PROMPT\n+ история + профиль)
llm --> dialogue : Уточняющий вопрос
dialogue -> session : update(session)
dialogue --> api : QueryResponse\n(stage=anamnesis, type=clarifying_question)
api --> java : AiChatResponse
java --> user : Уточняющий вопрос

note right of dialogue
  Повторяется до
  max_clarifying_questions (3)
  или достаточно данных
end note

== Этап 2: Синтез контекста (SYNTHESIS) ==

user -> java : Финальный ответ на вопросы
java -> api : POST /ai/chat
api -> dialogue : process_query(QueryRequest)
dialogue -> session : get_or_create(session_id)
session --> dialogue : Session(stage=SYNTHESIS)
dialogue -> llm : chat(SYNTHESIS_PROMPT\n+ симптомы + профиль)
llm --> dialogue : Клиническое резюме
dialogue -> session : update(session,\nclinical_summary)

== Этап 3: Генерация рекомендаций (RECOMMENDATION) ==

dialogue -> retriever : retrieve(clinical_summary)
retriever -> embed : embed_text(query)
embed --> retriever : query_vector [1024]
retriever -> qdrant : search(vector, top_k=10)
qdrant --> retriever : SearchResult[]
retriever --> dialogue : RetrievedChunk[]

dialogue -> llm : chat(RECOMMENDATION_PROMPT\n+ резюме + контекст + профиль)
llm --> dialogue : Текст рекомендаций

dialogue -> safety : check_allergies(meds, allergies)
safety --> dialogue : SafetyWarning[]
dialogue -> safety : check_drug_interactions(meds, current)
safety --> dialogue : SafetyWarning[]
dialogue -> safety : check_chronic_conditions(meds, conditions)
safety --> dialogue : SafetyWarning[]

dialogue -> session : delete(session_id)
dialogue --> api : QueryResponse\n(stage=recommendation,\ntype=final_recommendation)
api --> java : AiChatResponse +\ndisclaimer + sources
java --> user : Рекомендации +\nмедицинский дисклеймер

@enduml
