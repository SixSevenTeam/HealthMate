# Backend environment example for HealthMate
# Copy this file to .env and set real values.

# Database
DB_URL=jdbc:postgresql://localhost:5432/HealthMate_DB
DB_USERNAME=healthmate_user
DB_PASSWORD=healthmate_user

# Server
SERVER_PORT=8080
FRONTEND_URL=http://localhost:5173

# Security
JWT_SECRET=change_me_jwt_secret_min_32_chars
JWT_EXPIRATION_MS=86400000

# AES key for profile field encryption (diagnoses/allergies)
# IMPORTANT: Keep stable in one environment. Rotating requires data re-encryption.
AES_SECRET_KEY=change_me_aes_secret_min_32_chars

# Python service
PYTHON_SERVICE_URL=http://localhost:8001
PYTHON_INTERNAL_API_KEY=change_me_internal_api_key
